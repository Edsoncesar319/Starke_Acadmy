# Copie para backend/.env (não commitar). Valores vêm do painel Vercel → Storage → Uploads.

POSTGRES_URL=
Uploads_STORE_ID=store_xxxxxxxx
Uploads_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx
AUTH_SECRET_KEY=
BLOB_ACCESS=public
BLOB_STORE_NAME=Uploads

# Pagamentos PIX (Mercado Pago — recomendado em produção)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# SITE_PUBLIC_URL=https://starke-acadmy.vercel.app
# PIX_PAYMENT_PROVIDER=mercadopago
# PIX_RECEIVER_KEY=          # alternativa: chave PIX estática
# PIX_CHECKOUT_MOCK=true     # dev local sem gateway

# E-mail (recuperação de senha) — Gmail Starke Academy
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=edsonstarkeacademy@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=Starke Academy <edsonstarkeacademy@gmail.com>
SITE_PUBLIC_URL=https://starke-acadmy.vercel.app

# Opcional (legado / outro store):
# BLOB_READ_WRITE_TOKEN=
# BLOB_STORE_ID=
