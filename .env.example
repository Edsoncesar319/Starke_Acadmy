# --- Local development (defaults: SQLite + uploads/ folder) ---
# Copy to backend/.env if you want overrides locally.

# --- Vercel (obrigatório no dashboard) ---
# Project Settings → Build & Deployment → Framework Preset: Other (NÃO use "Services")
# O vercel.json na raiz define build, output (public/) e API (/api).

# --- Vercel production (Project Settings → Environment Variables) ---
# Created automatically when you add Storage integrations:

# Vercel Postgres / Neon (use pooled URL for serverless)
POSTGRES_URL=

# Vercel Blob (read/write token from Blob store)
BLOB_READ_WRITE_TOKEN=

# JWT signing (generate a long random string; required in production)
AUTH_SECRET_KEY=

# Optional overrides
# DATABASE_URL=postgresql://...
# API_PUBLIC_BASE_URL=/_/backend
# UPLOAD_DIR=/tmp/starke-uploads

# Note: on Vercel, server-side video uploads are limited to ~4 MB per request.
# Larger lesson videos require client-side Blob upload (not implemented yet).
