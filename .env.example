# --- Local (opcional: copie para backend/.env) ---
# Sem variáveis = SQLite em ./starke_elite.db e uploads em backend/uploads/

# --- Produção na Vercel (Settings → Environment Variables) ---
# Conecte Storage no projeto e adicione:

POSTGRES_URL=
BLOB_READ_WRITE_TOKEN=
AUTH_SECRET_KEY=
# PIX — recebimento direto na sua chave (prioridade se não houver Mercado Pago)
PIX_RECEIVER_KEY=0790b3c5-4904-4893-8c2b-6ddbb05d6623
# PIX_MERCHANT_NAME=Starke Academy
# PIX_MERCHANT_CITY=Sao Paulo
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...  (opcional; substitui PIX estático se definido)
# PIX_CHECKOUT_MOCK=true                 (só sem chave PIX e sem Mercado Pago)

# Opcionais
# DATABASE_URL=postgresql://...
# API_PUBLIC_BASE_URL=/api
# CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,https://seu-dominio.vercel.app

# Vídeos: upload direto ao Blob (api/blob-client-upload). Store privado = omita ou BLOB_ACCESS=private.
# BLOB_ACCESS=public   # só se o Blob store foi criado como Public
# Vídeos via servidor Python: limite ~4 MB na Vercel.
