# --- Local (opcional: copie para backend/.env) ---
# Sem variáveis = SQLite em ./starke_elite.db e uploads em backend/uploads/

# --- Produção na Vercel (Settings → Environment Variables) ---
# Conecte Storage → Blob (ex.: store "Uploads") ao projeto:

POSTGRES_URL=
# Token do store (Vercel cria automaticamente ao conectar o Blob):
BLOB_READ_WRITE_TOKEN=
# Store "Uploads" (padrão da documentação Vercel):
Uploads_STORE_ID=
Uploads_READ_WRITE_TOKEN=
# BLOB_STORE_NAME=Uploads
# BLOB_STORE_ID=
AUTH_SECRET_KEY=
# --- PIX / Pagamentos ---
# Produção (recomendado): Mercado Pago com confirmação automática via webhook
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
# URL pública do site (opcional; na Vercel usa VERCEL_URL automaticamente)
# SITE_PUBLIC_URL=https://starke-acadmy.vercel.app
# Forçar provedor: mercadopago | static | mock
# PIX_PAYMENT_PROVIDER=mercadopago

# Alternativa: PIX estático na sua chave (confirmação manual pelo aluno)
# PIX_RECEIVER_KEY=sua-chave-pix@email.com
# PIX_MERCHANT_NAME=Starke Academy
# PIX_MERCHANT_CITY=Sao Paulo

# Dev local sem gateway (QR mock)
# PIX_CHECKOUT_MOCK=true

# E-mail (recuperação de senha) — Gmail Starke Academy
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=edsonstarkeacademy@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=Starke Academy <edsonstarkeacademy@gmail.com>
SITE_PUBLIC_URL=https://starke-acadmy.vercel.app

# Opcionais
# DATABASE_URL=postgresql://...
# API_PUBLIC_BASE_URL=/api
# CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,https://seu-dominio.vercel.app

# access: 'public' (padrão quando Uploads_STORE_ID existe). Use private só se o store for Private:
# BLOB_ACCESS=private

# Vídeos em produção: /api/admin/lessons/upload-video (≤4 MB) + /api/blob-client-upload (maiores)
# Remova BLOB_STORE_ID/BLOB_READ_WRITE_TOKEN antigos se usar só o store "Uploads".
