{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "backend": {
      "entrypoint": "backend/app/main.py",
      "routePrefix": "/",
      "framework": "fastapi",
      "includeFiles": ["public/**", "backend/app/public/**"]
    }
  },
  "functions": {
    "api/blob-client-upload.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
